      <view class="bottom-spacer"></view>
    </scroll-view>
  </view>
</template>

<script setup lang="uts">
import { ref } from 'vue'
import { useAppStore } from '../../store/app.uts'

const appStore = useAppStore

const isFloatWindowEnabled = ref(false)
const hasPermission = ref(false)

const toggleFloatWindow = (e: any) => {
  const value = e.detail.value
  isFloatWindowEnabled.value = value

  if (value) {
    // 模拟检测原生系统权限
    setTimeout(() => {
      hasPermission.value = false // 模拟未授权，提示用户
      if(!hasPermission.value) {
        appStore.showToast('为了正常使用，请允许显示在其他应用上层')
      }
    }, 500)
  } else {
    appStore.showToast('已关闭悬浮助手')
  }
}

const goToSystemSettings = () => {
  appStore.showToast('请在系统列表中勾选恋爱话术键盘');
  // openIMESettings(); // 需要在真机编译时引入插件
  appStore.showToast('正在跳转系统设置...')
  // 在实际的原生插件开发中，这里会调用：
  // plus.android.importClass("android.provider.Settings");
  // 引导用户去开启 ACTION_MANAGE_OVERLAY_PERMISSION
  setTimeout(() => {
    hasPermission.value = true // 模拟用户已授权归来
    appStore.showToast('授权成功，悬浮球已激活')
  }, 1500)
}
</script>

