<template>
  <view class="container">
    <!-- 顶部渐变背景 -->
    <view class="header-bg">
      <view class="header-content">
        <text class="header-title">悬浮窗 & 键盘助手</text>
        <text class="header-desc">在微信/QQ等聊天软件中，无需切换 App 即可快速查话术、一键发送。</text>
      </view>
    </view>

    <scroll-view class="content-scroll" scroll-y>

      <!-- 主开关卡片 -->
      <view class="setting-card main-toggle-card">
        <view class="card-left">
          <view class="icon-wrap bg-gradient-pink">
            <text class="icon-text">✨</text>
          </view>
          <view class="card-info">
            <text class="card-title">启用聊天悬浮助手</text>
            <text class="card-desc">开启后，屏幕边缘将显示悬浮图标</text>
          </view>
        </view>
        <switch :checked="isFloatWindowEnabled" color="#ec4899" style="transform: scale(0.8);" @change="toggleFloatWindow" />
      </view>

      <!-- 权限检测提示 -->
      <view class="permission-banner" v-if="isFloatWindowEnabled && !hasPermission">
        <view class="permission-icon-wrap">
          <text class="permission-icon">⚠️</text>
        </view>
        <view class="permission-info">
          <text class="permission-title">缺少悬浮窗权限</text>
          <text class="permission-desc">请前往系统设置允许“显示在其他应用上层”</text>
        </view>
        <view class="permission-btn" @click="goToSystemSettings">
          <text class="permission-btn-text">去授权</text>
        </view>
      </view>

      <!-- 同步内容设置 -->
      <view class="section-title-row mt-4">
        <text class="section-title">显示内容设置</text>
      </view>
      <view class="setting-group">
        <view class="setting-item" @click="appStore.showToast('选择展示的分类')">
          <view class="setting-item-left">
            <text class="setting-item-icon">📂</text>
            <text class="setting-item-label">同步的话术库</text>
          </view>
          <view class="setting-item-right">
            <text class="setting-item-value">全部精选</text>
            <text class="setting-item-arrow">></text>
          </view>
        </view>
        <view class="divider"></view>
        <view class="setting-item" @click="appStore.showToast('选择收藏夹')">
          <view class="setting-item-left">
            <text class="setting-item-icon">❤️</text>
            <text class="setting-item-label">优先展示收藏夹</text>
          </view>
          <view class="setting-item-right">
            <text class="setting-item-value">约会话术</text>
            <text class="setting-item-arrow">></text>
          </view>
        </view>
      </view>

      <!-- 个性化设置 -->
      <view class="section-title-row mt-4">
        <text class="section-title">个性化</text>
      </view>
      <view class="setting-group">
        <view class="setting-item">
          <view class="setting-item-left">
            <text class="setting-item-icon">🎨</text>
            <text class="setting-item-label">悬浮窗主题</text>
          </view>
          <view class="setting-item-right">
            <text class="setting-item-value">粉粉甜心</text>
            <text class="setting-item-arrow">></text>
          </view>
        </view>
        <view class="divider"></view>
        <view class="setting-item">
          <view class="setting-item-left">
            <text class="setting-item-icon">📏</text>
            <text class="setting-item-label">悬浮窗大小</text>
          </view>
          <view class="setting-item-right">
            <text class="setting-item-value">标准</text>
            <text class="setting-item-arrow">></text>
          </view>
        </view>
      </view>

      <!-- 使用教程 -->
      <view class="tutorial-section">
        <view class="tutorial-header">
          <text class="tutorial-icon">💡</text>
          <text class="tutorial-title">使用教程</text>
        </view>
        <view class="tutorial-steps">
          <view class="step-item">
            <view class="step-number">1</view>
            <text class="step-text">打开本页面的开关，并授予悬浮窗权限。</text>
          </view>
          <view class="step-line"></view>
          <view class="step-item">
            <view class="step-number">2</view>
            <text class="step-text">打开微信或QQ等聊天界面，点击屏幕边缘出现的 ✨ 悬浮球。</text>
          </view>
          <view class="step-line"></view>
          <view class="step-item">
            <view class="step-number">3</view>
            <text class="step-text">在弹出的微型话术面板中搜索或选择高分回复，点击“发送”。</text>
          </view>
        </view>
        <!-- 模拟预览图 -->
        <view class="preview-box">
          <view class="preview-chat-mock">
            <view class="mock-bubble-left">在干嘛呢？</view>
            <view class="mock-fab-demo">
              <text class="mock-fab-icon">✨</text>
            </view>
            <view class="mock-bubble-right">刚忙完，正准备想你呢~</view>
