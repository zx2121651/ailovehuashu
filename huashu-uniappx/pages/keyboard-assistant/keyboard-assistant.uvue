.mock-bubble-right { background-color: #ec4899; padding: 10px 14px; border-radius: 16px; align-self: flex-end; font-size: 12px; color: #ffffff; box-shadow: 0 2px 4px rgba(236,72,153,0.3); }
.mock-fab-demo { position: absolute; right: -8px; top: 20px; width: 40px; height: 40px; border-radius: 20px; background-image: linear-gradient(to bottom right, #f43f5e, #ec4899); align-items: center; justify-content: center; box-shadow: 0 4px 10px rgba(236,72,153,0.4); border-width: 2px; border-style: solid; border-color: #ffffff; z-index: 10; }
