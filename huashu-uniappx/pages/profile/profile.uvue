.p-4 { padding: 16px; }

.avatar-wrapper { width: 72px; height: 72px; }
.avatar-img { width: 100%; height: 100%; }
.edit-badge { width: 20px; height: 20px; }

.id-badge { align-self: flex-start; }

.stat-item { padding-top: 8px; padding-bottom: 8px; }
.divider { width: 1px; height: 30px; margin-top: 12px; }

.task-card { height: 80px; }
.bg-orange-50 { background-color: #fff7ed; }
.bg-blue-50 { background-color: #eff6ff; }
.bg-orange-200 { background-color: #fed7aa; }
.bg-blue-200 { background-color: #bfdbfe; }
.border-orange-100 { border-color: #ffedd5; }
.border-blue-100 { border-color: #dbeafe; }
.text-orange-600 { color: #ea580c; }
.text-blue-600 { color: #2563eb; }
.text-orange-700 { color: #c2410c; }
.text-blue-700 { color: #1d4ed8; }
.icon-circle { width: 32px; height: 32px; border-radius: 16px; align-items: center; justify-content: center; }

.bg-gray-900 { background-color: #111827; }
.border-gray-700 { border-color: #374151; }
.bg-yellow-400 { background-color: #facc15; }
.text-yellow-400 { color: #facc15; }

.icon-box { width: 44px; height: 44px; align-items: center; justify-content: center; }

.text-2xl { font-size: 24px; }
.w-px { width: 1px; }

.mr-4 { margin-right: 16px; }
.mb-6 { margin-bottom: 24px; }
.pb-24 { padding-bottom: 96px; }

.vip-blur-circle { position: absolute; right: -40px; top: -40px; width: 128px; height: 128px; background-color: rgba(234, 179, 8, 0.1); border-radius: 64px; }
.vip-btn { padding: 6px 12px; }
.list-item { background-color: #ffffff; }
.list-item:active { background-color: #f9fafb; }
</style>
