.q-badge-text { font-size: 11px; font-weight: bold; color: #ffffff; }
.q-text { font-size: 18px; font-weight: bold; color: #1f2937; flex: 1; line-height: 1.5; }

.answers-section { background-color: #ffffff; padding: 20px; margin-bottom: 12px; }
.answers-title-row { flex-direction: row; align-items: center; margin-bottom: 20px; }
.answers-title { font-size: 16px; font-weight: bold; color: #1f2937; margin-right: 8px; }
.answers-count { font-size: 12px; font-weight: bold; color: #9ca3af; background-color: #f3f4f6; padding: 2px 8px; border-radius: 10px; }

.answers-list { flex-direction: column; }
.answer-card { background-color: #ffffff; border-radius: 20px; padding: 20px; margin-bottom: 16px; border-width: 1px; border-style: solid; border-color: #e5e7eb; position: relative; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05); }
.answer-idx-badge { position: absolute; top: -10px; left: -10px; width: 24px; height: 24px; border-radius: 12px; background-color: #ec4899; align-items: center; justify-content: center; border-width: 2px; border-style: solid; border-color: #ffffff; box-shadow: 0 2px 4px 0 rgba(236, 72, 153, 0.3); }
.idx-text { font-size: 12px; font-weight: bold; color: #ffffff; margin-top: -2px; }

.answer-text { font-size: 15px; color: #374151; line-height: 1.6; margin-bottom: 16px; font-weight: bold; }

.copy-btn { flex-direction: row; align-items: center; justify-content: center; background-color: #fdf2f8; padding: 10px; border-radius: 12px; border-width: 1px; border-style: solid; border-color: #fce7f3; }
.copy-btn-active { background-color: #ec4899; border-color: #ec4899; }
.copy-btn-icon { font-size: 14px; margin-right: 4px; color: #db2777; }
.copy-btn-active .copy-btn-icon { color: #ffffff; }
.copy-btn-text { font-size: 13px; font-weight: bold; color: #db2777; }
.copy-btn-text-active { color: #ffffff; }

.comments-section { background-color: #ffffff; padding: 20px; }
.comments-title { font-size: 16px; font-weight: bold; color: #1f2937; margin-bottom: 16px; }
.comments-empty { align-items: center; justify-content: center; padding: 40px 0; background-color: #f9fafb; border-radius: 16px; }
.comments-empty-text { font-size: 13px; color: #9ca3af; }

