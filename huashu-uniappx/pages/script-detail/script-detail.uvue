<template>
  <view class="page-container">
    <scroll-view class="scroll-content" scroll-y>
      <!-- Title Area -->
      <view class="detail-header">
        <view class="q-badge">
          <text class="q-badge-text">对方说</text>
        </view>
        <text class="q-text" :lines="4">{{ script.question || '加载中...' }}</text>
      </view>

      <!-- Answers List -->
      <view class="answers-section">
        <view class="answers-title-row">
          <text class="answers-title">全部高分回复</text>
          <text class="answers-count">{{ script.answers ? script.answers.length : 0 }}条</text>
        </view>

        <view class="answers-list" v-if="script.answers && script.answers.length > 0">
          <view v-for="(answer, idx) in script.answers" :key="idx" class="answer-card">
            <view class="answer-idx-badge">
              <text class="idx-text">{{ idx + 1 }}</text>
            </view>
            <text class="answer-text">{{ answer }}</text>

            <view class="copy-btn" :class="[copiedIndex === idx ? 'copy-btn-active' : '']" @click="handleCopy(idx, answer)">
              <text class="copy-btn-icon">{{ copiedIndex === idx ? '✓' : '📋' }}</text>
              <text class="copy-btn-text" :class="[copiedIndex === idx ? 'copy-btn-text-active' : '']">{{ copiedIndex === idx ? '已复制' : '一键复制' }}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- Mock Comment Section Placeholder -->
      <view class="comments-section">
        <text class="comments-title">评论区 (开发中)</text>
        <view class="comments-empty">
          <text class="comments-empty-text">暂无评论，快来抢沙发吧~</text>
        </view>
      </view>

      <view class="bottom-spacer"></view>
    </scroll-view>
  </view>
</template>

<script setup lang="uts">
import { ref, onMounted } from 'vue'
import { useAppStore } from '../../store/app.uts'

const appStore = useAppStore

const script = ref<any>({})
const copiedIndex = ref(-1)

const copiedId = ref(-1)

const question = ref('加载中...')
const answers = ref<string[]>([])
const comments = ref<any[]>([])
const loading = ref(false)

onMounted(() => {
  // Mock fetching script detail based on ID from options
  // Here we just set a mock object directly since it's a demonstration
  script.value = {
    id: 's1',
    question: '你到底喜欢我什么？',
    answers: [
      '喜欢你这个问题问得好，让我有了一辈子时间来回答。',
      '刚开始喜欢你的可爱，后来发现你浑身都是闪光点。',
      '这就像问我为什么喜欢呼吸一样，是本能。'
    ]
  }
})

const handleCopy = (idx: number, text: string) => {
  uni.setClipboardData({
    data: text,
    success: () => {
      copiedIndex.value = idx
      appStore.showToast('回复已复制')
      setTimeout(() => { copiedIndex.value = -1 }, 2000)
    }
  })
}
</script>

