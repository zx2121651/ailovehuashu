.qrcode-emoji { font-size: 32px; margin-bottom: 8px; }
.qrcode-tip { font-size: 10px; color: #9ca3af; }
.qrcode-desc { font-size: 11px; color: #6b7280; }

.action-bar { flex-direction: row; justify-content: space-between; }
.action-btn { flex: 1; flex-direction: row; align-items: center; justify-content: center; padding: 14px 0; border-radius: 24px; }
.share-btn { background-color: #10b981; margin-right: 12px; box-shadow: 0 8px 16px rgba(16,185,129,0.2); }
.save-btn { background-image: linear-gradient(to right, #ec4899, #f43f5e); box-shadow: 0 8px 16px rgba(236,72,153,0.3); }
.action-btn-icon { font-size: 16px; margin-right: 6px; }
.action-btn-text { font-size: 14px; font-weight: bold; color: #ffffff; }

