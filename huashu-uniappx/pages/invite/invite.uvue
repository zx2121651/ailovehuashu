.reward-num { font-size: 32px; font-weight: 900; color: #e11d48; margin-right: 4px; }
.reward-unit { font-size: 14px; color: #e11d48; font-weight: bold; }

.poster-steps { flex-direction: row; align-items: center; justify-content: space-between; width: 100%; margin-bottom: 32px; padding: 0 10px; z-index: 10; }
.step-item { align-items: center; width: 70px; }
.step-num-wrap { width: 24px; height: 24px; border-radius: 12px; background-color: #fbcfe8; align-items: center; justify-content: center; margin-bottom: 8px; }
.step-num { font-size: 12px; color: #db2777; font-weight: bold; }
.step-text { font-size: 11px; color: #4b5563; text-align: center; line-height: 1.4; }
.step-divider { width: 24px; height: 1px; background-color: #fce7f3; margin-top: -24px; }

.code-section { width: 100%; align-items: center; margin-bottom: 32px; z-index: 10; }
.code-label { font-size: 12px; color: #9ca3af; margin-bottom: 8px; }
.code-box { flex-direction: row; align-items: center; background-color: #f9fafb; padding: 6px 6px 6px 20px; border-radius: 24px; border-width: 1px; border-style: dashed; border-color: #d1d5db; width: 200px; justify-content: space-between; }
.code-text { font-size: 20px; font-weight: 900; color: #1f2937; letter-spacing: 2px; }
.copy-btn { background-image: linear-gradient(to right, #ec4899, #f43f5e); padding: 8px 16px; border-radius: 16px; }
