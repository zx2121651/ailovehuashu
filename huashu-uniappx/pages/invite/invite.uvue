<template>
  <view class="container">
    <scroll-view class="scroll-area" scroll-y>
      <view class="poster-card">
        <!-- 装饰背景 -->
        <view class="poster-bg-glow"></view>

        <view class="poster-header">
          <text class="poster-title">邀请好友 赚积分</text>
          <text class="poster-subtitle">每成功邀请一位好友注册，即可获得</text>
          <view class="reward-box">
            <text class="reward-num">50</text>
            <text class="reward-unit">积分</text>
          </view>
        </view>

        <view class="poster-steps">
          <view class="step-item">
            <view class="step-num-wrap"><text class="step-num">1</text></view>
            <text class="step-text">分享邀请码给好友</text>
          </view>
          <view class="step-divider"></view>
          <view class="step-item">
            <view class="step-num-wrap"><text class="step-num">2</text></view>
            <text class="step-text">好友注册时填写</text>
          </view>
          <view class="step-divider"></view>
          <view class="step-item">
            <view class="step-num-wrap"><text class="step-num">3</text></view>
            <text class="step-text">双方各得50积分</text>
          </view>
        </view>

        <view class="code-section">
          <text class="code-label">我的专属邀请码</text>
          <view class="code-box">
            <text class="code-text">{{ inviteCode }}</text>
            <view class="copy-btn" @click="copyCode">
              <text class="copy-btn-text">复制</text>
            </view>
          </view>
        </view>

        <!-- 模拟二维码 -->
        <view class="qrcode-section">
          <view class="qrcode-placeholder">
            <text class="qrcode-emoji">📱</text>
            <text class="qrcode-tip">扫码下载 App</text>
          </view>
          <text class="qrcode-desc">长按保存海报，分享至微信 / 朋友圈</text>
        </view>
      </view>

      <view class="action-bar">
        <view class="action-btn share-btn" @click="shareToWechat">
          <text class="action-btn-icon">💬</text>
          <text class="action-btn-text">微信分享</text>
        </view>
        <view class="action-btn save-btn" @click="savePoster">
          <text class="action-btn-icon">⬇️</text>
          <text class="action-btn-text">保存海报</text>
        </view>
      </view>

      <view class="bottom-spacer"></view>
    </scroll-view>
  </view>
</template>

<script setup lang="uts">
import { ref } from 'vue'
import { useAppStore } from '../../store/app.uts'

const appStore = useAppStore

const inviteCode = ref(appStore.userInfo?.id || 'HSHU8829')

const copyCode = () => {
  uni.setClipboardData({
    data: inviteCode.value,
    success: () => {
      appStore.showToast('邀请码已复制，快去分享吧！')
    }
  })
}

const shareToWechat = () => {
  appStore.showToast('正在调起微信分享...')
}

const savePoster = () => {
  uni.showLoading({ title: '正在生成海报...' })
  setTimeout(() => {
    uni.hideLoading()
    appStore.showToast('海报已保存到相册')
  }, 1500)
}
</script>

<style>
page { background-color: #fdf2f8; height: 100%; }
.container { flex: 1; display: flex; flex-direction: column; height: 100%; }

.scroll-area { flex: 1; padding: 20px; }

.poster-card { background-color: #ffffff; border-radius: 24px; padding: 32px 24px; align-items: center; box-shadow: 0 20px 40px -10px rgba(236,72,153,0.15); position: relative; overflow: hidden; margin-bottom: 24px; }
.poster-bg-glow { position: absolute; top: -50px; left: -50px; width: 150px; height: 150px; background-image: linear-gradient(to bottom right, rgba(244,63,94,0.1), rgba(236,72,153,0)); border-radius: 75px; }

.poster-header { align-items: center; margin-bottom: 32px; z-index: 10; }
.poster-title { font-size: 24px; font-weight: 900; color: #db2777; margin-bottom: 8px; letter-spacing: 1px; }
.poster-subtitle { font-size: 13px; color: #6b7280; margin-bottom: 12px; }
