            <view v-for="tag in courseData.tags" :key="tag" class="tag-badge bg-pink-50 px-2_5 py-1 rounded-md border border-pink-100 mr-2">
              <text class="text-pink-600 text-xs font-bold">{{ tag }}</text>
            </view>
          </view>
          <view class="flex-row items-center">
            <text class="text-yellow-400 text-sm mr-1">⭐</text>
            <text class="text-xs text-gray-500 font-medium">{{ courseData.rating }} ({{ courseData.students }}人)</text>
          </view>
        </view>
        <text class="text-xl font-extrabold text-gray-800 mb-2">{{ courseData.title }}</text>
        <text class="text-sm text-gray-500 leading-relaxed">{{ courseData.desc }}</text>
      </view>

      <!-- Tabs -->
      <view class="course-tabs flex-row border-b border-gray-200 mb-4 px-2">
        <view class="tab-item flex-1 flex-row items-center justify-center py-3 relative" @click="courseTab = 'outline'">
          <text class="text-sm font-bold transition-colors" :class="[courseTab === 'outline' ? 'text-gray-800' : 'text-gray-400']">课程目录</text>
          <view v-if="courseTab === 'outline'" class="active-line absolute bottom-0 w-8 h-1 bg-pink-500 rounded-t-full"></view>
        </view>
        <view class="tab-item flex-1 flex-row items-center justify-center py-3 relative" @click="courseTab = 'intro'">
          <text class="text-sm font-bold transition-colors" :class="[courseTab === 'intro' ? 'text-gray-800' : 'text-gray-400']">课程简介</text>
          <view v-if="courseTab === 'intro'" class="active-line absolute bottom-0 w-8 h-1 bg-pink-500 rounded-t-full"></view>
        </view>
      </view>

      <!-- Tab Content -->
      <view class="tab-content min-h-[300px]">
        <!-- Outline Tab -->
        <view v-if="courseTab === 'outline'" class="outline-list flex-col space-y-3">
          <view class="flex-row justify-between items-center px-1 mb-2">
            <text class="text-sm font-bold text-gray-700">🕒 更新至第 {{ courseData.lessons.length }} 节</text>
            <text class="text-xs text-gray-400">完整版共 12 节</text>
          </view>

          <view
            v-for="(lesson, idx) in courseData.lessons"
            :key="idx"
            class="lesson-item flex-row justify-between items-center p-4 rounded-2xl border transition-all mb-3"
            :class="[activeLesson === idx ? 'bg-pink-50 border-pink-200 shadow-sm' : 'bg-white border-gray-100']"
            @click="handlePlayLesson(idx)"
          >
            <view class="flex-row items-center flex-1 pr-4">
              <view v-if="activeLesson === idx" class="w-8 h-8 rounded-full bg-pink-500 flex-row items-center justify-center mr-3 shadow-sm shadow-pink-200">
                <text class="text-white text-xs animate-spin">🌀</text>
              </view>
              <view v-else class="w-8 h-8 rounded-full flex-row items-center justify-center mr-3" :class="[lesson.free ? 'bg-pink-100' : 'bg-gray-100']">
                <text class="text-xs font-bold" :class="[lesson.free ? 'text-pink-500' : 'text-gray-400']">{{ idx + 1 }}</text>
              </view>

              <view class="flex-col">
                <text class="text-sm font-bold leading-tight" :class="[activeLesson === idx ? 'text-pink-600' : (lesson.free ? 'text-gray-800' : 'text-gray-500')]">{{ lesson.title }}</text>
                <view class="flex-row items-center mt-1_5">
                  <text class="text-xs mr-2" :class="[activeLesson === idx ? 'text-pink-400' : 'text-gray-400']">{{ lesson.duration }}</text>
                  <view v-if="lesson.free && activeLesson !== idx" class="bg-green-50 border border-green-200 px-1_5 py-0_5 rounded">
                    <text class="text-green-500 font-medium" style="font-size: 10px;">试看</text>
                  </view>
                  <view v-if="activeLesson === idx" class="bg-pink-100 px-1_5 py-0_5 rounded">
                    <text class="text-pink-500 font-bold" style="font-size: 10px;">正在播放</text>
                  </view>
                </view>
              </view>
            </view>

            <view class="right-icon shrink-0">
              <text v-if="lesson.free" :class="['text-xl', activeLesson === idx ? 'text-pink-500' : 'text-pink-400 opacity-60']">
                {{ activeLesson === idx ? '⏸' : '▶' }}
              </text>
              <view v-else class="bg-gray-50 p-1_5 rounded-full border border-gray-100">
                <text class="text-gray-400 text-sm">🔒</text>
              </view>
            </view>
          </view>
        </view>

        <!-- Intro Tab -->
        <view v-if="courseTab === 'intro'" class="intro-content flex-col space-y-4">
          <view class="bg-white rounded-3xl p-5 shadow-sm border border-gray-100 mb-4">
            <text class="font-bold text-gray-800 text-sm mb-4">👤 导师介绍</text>
            <view class="flex-row items-center mb-3">
              <image :src="courseData.instructor.avatar" class="w-12 h-12 rounded-full border border-gray-100 mr-3" mode="aspectFill" />
              <view class="flex-col">
                <text class="font-bold text-gray-800 text-sm">{{ courseData.instructor.name }}</text>
                <text class="text-xs text-gray-500 mt-0_5">{{ courseData.instructor.title }}</text>
              </view>
            </view>
            <view class="bg-gray-50 p-3 rounded-xl border border-gray-100">
              <text class="text-xs text-gray-600 leading-relaxed">苏苏导师专注于情感关系升温与脱单实战指导，曾帮助上万名学员成功脱单、挽回前任。擅长利用心理学原理打破聊天僵局。</text>
            </view>
          </view>

          <view class="bg-white rounded-3xl p-5 shadow-sm border border-gray-100 mb-4">
            <text class="font-bold text-gray-800 text-sm mb-3">✨ 你将获得</text>
            <view class="flex-col space-y-3">
              <view class="flex-row items-start mb-2">
                <text class="text-green-500 mr-2">✓</text>
                <text class="text-sm text-gray-600 leading-relaxed flex-1">掌握 10+ 种高频聊天场景的推拉技巧，告别冷场。</text>
              </view>
              <view class="flex-row items-start mb-2">
                <text class="text-green-500 mr-2">✓</text>
                <text class="text-sm text-gray-600 leading-relaxed flex-1">学会通过情绪价值吸引对方，建立强大的个人框架。</text>
              </view>
              <view class="flex-row items-start">
                <text class="text-green-500 mr-2">✓</text>
                <text class="text-sm text-gray-600 leading-relaxed flex-1">突破友谊区，实现从普通朋友到暧昧对象的快速跃迁。</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>

    <!-- Bottom Action Bar -->
    <view v-if="activeLesson === -1" class="absolute bottom-0 w-full bg-white-90 border-t border-gray-100 p-3 px-5 z-40 pb-safe shadow-top flex-row items-center justify-between">
      <view class="consult-btn w-12 h-12 bg-gray-50 rounded-2xl flex-col items-center justify-center border border-gray-200 mr-3" @click="goToAI">
        <text class="text-gray-600 text-lg mb-0_5">💬</text>
        <text class="text-gray-500 font-medium" style="font-size: 9px;">咨询</text>
      </view>
      <button class="flex-1 bg-gradient-black text-white font-bold py-3_5 rounded-2xl shadow-lg flex-row items-center justify-center active:scale-95" @click="openVipModal">
        <text class="text-yellow-400 text-lg mr-2">👑</text>
        <text class="text-white text-sm font-bold">解锁全部课程</text>
      </button>
