          <view class="absolute inset-0 flex-row items-center justify-center z-20 pointer-events-none">
            <view v-if="isPlaying" class="flex-col items-center bg-black-40 px-4 py-3 rounded-2xl">
              <text class="text-pink-500 text-3xl animate-spin mb-2">🌀</text>
              <text class="text-white text-xs font-bold tracking-widest">正在缓冲视频...</text>
            </view>
            <view v-else class="play-btn-wrap w-16 h-16 bg-white-20 rounded-full flex-row items-center justify-center pointer-events-auto border border-white-30" @click="isPlaying = true">
              <text class="text-white text-4xl ml-1">▶</text>
            </view>
          </view>
          <!-- 顶部标题栏 -->
          <view class="video-top bg-gradient-to-b p-5 pb-10 z-10 flex-row justify-between items-start">
            <text class="text-white text-sm font-bold flex-1 pr-4" style="lines: 1; text-overflow: ellipsis; overflow: hidden;">{{ courseData.lessons[activeLesson].title }}</text>
            <view class="hd-badge bg-black-40 px-2 py-0_5 rounded border border-white-20">
              <text class="text-white-80 text-xs">高清</text>
            </view>
          </view>
          <!-- 底部控制栏 -->
          <view class="video-bottom bg-gradient-to-t p-5 pt-12 z-10 flex-col">
            <view class="progress-bar w-full h-1_5 bg-white-30 rounded-full mb-4 relative overflow-hidden">
              <view class="progress-fill absolute top-0 left-0 h-full bg-gradient-pink rounded-full transition-all" :style="{ width: isPlaying ? '33%' : '0%' }"></view>
              <view class="progress-thumb absolute top-1_2 -translate-y-1_2 w-4 h-4 bg-white rounded-full shadow-md border-2 border-pink-500 transition-all" :style="{ left: isPlaying ? '33%' : '0' }"></view>
            </view>
            <view class="flex-row justify-between items-center text-white">
              <view class="flex-row items-center space-x-5">
                <text class="text-2xl cursor-pointer text-white" @click="isPlaying = !isPlaying">{{ isPlaying ? '⏸' : '▶' }}</text>
                <text class="text-xs font-bold opacity-90 font-mono ml-4 text-white">
                  {{ isPlaying ? '04:12' : '00:00' }} / {{ courseData.lessons[activeLesson].duration }}
                </text>
              </view>
              <text class="text-lg cursor-pointer text-white opacity-90" @click="appStore.showToast('全屏模式开发中')">🔲</text>
            </view>
          </view>
        </view>
        <view v-else class="preview-wrap w-full h-full relative" @click="handlePlayLesson(0)">
          <image src="https://images.unsplash.com/photo-1518621736915-f3b1c41bfd00?q=80&w=800&auto=format&fit=crop" class="w-full h-full opacity-70" mode="aspectFill"></image>
          <view class="absolute inset-0 bg-black-40 flex-col items-center justify-center">
            <view class="badge-top-left absolute top-4 left-4 bg-pink-500 px-2_5 py-1 rounded border border-pink-400">
              <text class="text-white text-xs font-bold">精品课程</text>
            </view>
            <view class="play-btn-wrap w-16 h-16 bg-white-20 rounded-full flex-row items-center justify-center border border-white-30 mb-3">
