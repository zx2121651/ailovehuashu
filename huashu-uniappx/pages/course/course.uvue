  </view>
</template>

<script setup lang="uts">
import { ref, reactive, onMounted } from 'vue'
import { useAppStore } from '../../store/app.uts'
import { getFeaturedCourse } from '../../services/api.uts'

const appStore = useAppStore

const activeLesson = ref(-1)
const isPlaying = ref(false)
const courseTab = ref('outline')

const courseData = reactive({
  title: '加载中...',
  desc: '',
  tags: ['高情商', '实战解析', '脱单必备'],
  rating: 4.9,
  students: '1.2w',
  instructor: {
    name: '苏苏导师',
    title: '平台首席情感分析师',
    avatar: 'https://api.dicebear.com/7.x/avataaars/svg?seed=Susu&backgroundColor=fce7f3'
  },
  lessons: [
    { title: '先导课：为什么你的聊天总是会死机？', duration: '12:45', free: true }
  ] as any[]
})

onMounted(async () => {
  try {
    const data = await getFeaturedCourse()
    if (data) {
      courseData.title = data.title || courseData.title
      courseData.desc = data.desc || courseData.desc
      if (data.tags) courseData.tags = data.tags
      if (data.rating) courseData.rating = data.rating
      if (data.students) courseData.students = data.students
      if (data.instructor) courseData.instructor = data.instructor
      if (data.lessons) courseData.lessons = data.lessons
    }
  } catch (e) {
    console.error('获取课程详情失败', e)
    courseData.title = '加载失败'
    courseData.desc = '请检查网络连接后重试'
    courseData.lessons = []
  }
})

const handlePlayLesson = (idx: number) => {
  if (courseData.lessons[idx].free) {
    activeLesson.value = idx
    isPlaying.value = true
    courseTab.value = 'outline'
  } else {
    appStore.showVipModal = true
  }
}

const goBack = () => {
  uni.navigateBack({ delta: 1 })
}

const goToAI = () => {
  uni.navigateTo({ url: '/pages/ai/ai' })
}

const openVipModal = () => {
  appStore.showVipModal = true
}

</script>

