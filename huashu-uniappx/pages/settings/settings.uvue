      <!-- Account Section -->
      <view class="section mb-6">
        <text class="text-xs text-gray-500 font-bold mb-2 ml-2">账号设置</text>
        <view class="list-card bg-white rounded-2xl shadow-sm border border-gray-50 flex-col overflow-hidden">
          <view class="list-item flex-row justify-between items-center p-4 border-b border-gray-50" @click="appStore.showToast('修改资料开发中')">
            <text class="text-sm text-gray-800 font-medium">修改个人资料</text>
            <text class="text-gray-300">></text>
          </view>
          <view class="list-item flex-row justify-between items-center p-4" @click="appStore.showToast('账号绑定开发中')">
            <text class="text-sm text-gray-800 font-medium">账号绑定</text>
            <view class="flex-row items-center">
              <text class="text-xs text-gray-400 mr-2">已绑定微信</text>
              <text class="text-gray-300">></text>
            </view>
          </view>
