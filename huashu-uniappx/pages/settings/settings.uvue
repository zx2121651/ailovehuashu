      </view>

      <!-- App Section -->
      <view class="section mb-6">
        <text class="text-xs text-gray-500 font-bold mb-2 ml-2">应用设置</text>
        <view class="list-card bg-white rounded-2xl shadow-sm border border-gray-50 flex-col overflow-hidden">
          <view class="list-item flex-row justify-between items-center p-4 border-b border-gray-50" @click="appStore.showToast('清除缓存成功')">
            <text class="text-sm text-gray-800 font-medium">清除缓存</text>
            <text class="text-xs text-gray-400">12.5 MB</text>
          </view>
          <view class="list-item flex-row justify-between items-center p-4" @click="appStore.showToast('已是最新版本')">
            <text class="text-sm text-gray-800 font-medium">检查更新</text>
