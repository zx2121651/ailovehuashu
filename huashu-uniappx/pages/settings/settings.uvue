      <!-- Logout Button -->
      <view class="logout-btn w-full py-3_5 bg-white border border-gray-100 rounded-xl shadow-sm flex-row justify-center items-center active:bg-gray-50" @click="handleLogout">
        <text class="text-red-500 font-bold text-base">退出登录</text>
      </view>

    </scroll-view>
  </view>
</template>

<script setup lang="uts">
import { useAppStore } from '../../store/app.uts'

const appStore = useAppStore

const goBack = () => {
  uni.navigateBack({ delta: 1 })
}

const handleLogout = () => {
  uni.showModal({
    title: '提示',
    content: '确定要退出登录吗？',
    success: function (res) {
      if (res.confirm) {
        appStore.clearToken()
        appStore.showToast('已退出登录')
        // 跳转到首页或者登录页
        uni.reLaunch({ url: '/pages/index/index' })
      }
    }
  })
}
</script>

