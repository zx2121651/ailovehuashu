.intro-desc { font-size: 13px; color: #6b7280; line-height: 1.6; }

.form-container { padding: 20px; }
.form-label { font-size: 14px; font-weight: bold; color: #374151; margin-bottom: 10px; margin-top: 16px; }
.form-label:first-child { margin-top: 0; }
.custom-input { background-color: #ffffff; width: 100%; height: 100px; border-radius: 12px; padding: 12px; font-size: 14px; color: #1f2937; border-width: 1px; border-style: solid; border-color: #e5e7eb; }

.fixed-bottom { position: fixed; bottom: 0; left: 0; right: 0; padding: 12px 16px 24px; background-color: #ffffff; border-top-width: 1px; border-top-style: solid; border-top-color: #f3f4f6; flex-direction: row; align-items: center; justify-content: space-between; }
.price-row { flex-direction: row; align-items: baseline; }
.price-label { font-size: 12px; color: #6b7280; }
.price-value { font-size: 20px; font-weight: bold; color: #ef4444; }
