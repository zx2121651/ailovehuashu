<template>
  <view class="page-container">
    <scroll-view class="scroll-area" scroll-y>
      <view class="intro-box">
        <text class="intro-title">专属话术定制</text>
        <text class="intro-desc">遇到棘手的聊天情况？请将对方的原话以及你想要传达的核心意图告诉我们，金牌导师将为你量身定制高情商回复。</text>
      </view>

      <view class="form-container">
        <text class="form-label">当前的聊天情境</text>
        <textarea class="custom-input" placeholder="请描述你们的关系阶段，或者刚才聊了什么..." v-model="formData.context"></textarea>

        <text class="form-label">对方的原话</text>
        <textarea class="custom-input" placeholder="例如：我觉得我们还是做朋友比较好..." v-model="formData.message"></textarea>

        <text class="form-label">你的目标</text>
        <textarea class="custom-input" placeholder="例如：我想幽默地化解尴尬，并保持联系..." v-model="formData.goal"></textarea>
      </view>
    </scroll-view>

    <view class="fixed-bottom">
      <view class="price-row">
        <text class="price-label">定制服务费：</text>
        <text class="price-value">¥ 9.9</text>
      </view>
      <button class="primary-btn" @click="submitCustom">支付并提交</button>
    </view>
  </view>
</template>

<script setup lang="uts">
import { reactive } from 'vue'
import { useAppStore } from '../../store/app.uts'

const appStore = useAppStore

const formData = reactive({
  context: '',
  message: '',
  goal: ''
})

const submitCustom = () => {
  if (!formData.context || !formData.message || !formData.goal) {
    appStore.showToast('请将定制信息填写完整')
    return
  }

  appStore.showToast('支付接口开发中...')
}
</script>

<style>
page { display: flex; flex-direction: column; height: 100%; background-color: #f5f7fa; }
.page-container { flex: 1; background-color: #f5f7fa; padding-bottom: 100px; }
.scroll-area { flex: 1; }

.intro-box { background-color: #ffffff; padding: 24px 20px; }
