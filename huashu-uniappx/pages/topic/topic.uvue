<template>
  <view class="page-container">
    <scroll-view class="scroll-area" scroll-y>
      <view class="hero-section">
        <image class="hero-image" src="https://images.unsplash.com/photo-1516726817505-f5ed825624d8?q=80&w=800&auto=format&fit=crop" mode="aspectFill"></image>
        <view class="hero-overlay"></view>
        <view class="hero-stats">
          <text class="hero-stats-icon">👥</text>
          <text class="hero-stats-text">2.5W 人在看</text>
        </view>
        <view class="hero-content">
          <view class="hero-badge">
            <text class="hero-badge-icon">🔥</text>
            <text class="hero-badge-text">本周强推</text>
          </view>
          <text class="hero-title">情人节特辑：如何用一句话让她沦陷？</text>
          <text class="hero-desc">收录全网 50+ 句高赞表白神回复，拒绝油腻土味情话，用顶级高情商一秒搞定心动女孩。</text>
        </view>
      </view>

      <view class="content-section">
        <view class="section-header">
          <text class="section-title">✨ 专题精选语录</text>
          <text class="section-action" @click="handleCopyAll">一键复制</text>
        </view>

        <view class="quote-list">
          <view class="quote-item" v-for="(item, index) in quotes" :key="index">
            <text class="quote-text">{{ item }}</text>
            <view class="quote-actions">
              <view class="action-btn" @click="handleCopy(item)">
                <text class="action-icon">📋</text>
                <text class="action-text">复制</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</template>

<script setup lang="uts">
import { ref } from 'vue'
import { useAppStore } from '../../store/app.uts'

const appStore = useAppStore()

const quotes = ref([
  '“我总觉得，我应该早点认识你。不过现在也不算晚，余生还长。”',
  '“和你在一起的时候，我从没羡慕过任何人。”',
  '“这世界欠你的温柔，我来给。”'
])

const handleCopy = (text: string) => {
  uni.setClipboardData({
    data: text,
    success: () => {
      appStore.showToast('已复制')
    }
  })
}

const handleCopyAll = () => {
  const allText = quotes.value.join('\n')
  uni.setClipboardData({
    data: allText,
    success: () => {
      appStore.showToast('已复制全部')
    }
  })
}
</script>

