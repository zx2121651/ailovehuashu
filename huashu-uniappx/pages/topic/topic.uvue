.hero-overlay { position: absolute; left: 0; right: 0; top: 0; bottom: 0; background-image: linear-gradient(to top, rgba(17,24,39,0.9), rgba(17,24,39,0.5), transparent); }

.hero-stats { position: absolute; top: 16px; right: 16px; flex-direction: row; align-items: center; background-color: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.3); padding: 4px 12px; border-radius: 20px; }
