.hero-stats-text { font-size: 11px; color: #ffffff; font-weight: bold; }

.hero-content { position: absolute; left: 20px; right: 20px; bottom: 30px; }
.hero-badge { flex-direction: row; align-items: center; background-image: linear-gradient(to right, #ec4899, #f43f5e); padding: 4px 10px; border-radius: 20px; margin-bottom: 12px; align-self: flex-start; }
.hero-badge-icon { font-size: 10px; margin-right: 4px; color: #fff; }
.hero-badge-text { font-size: 10px; color: #ffffff; font-weight: bold; }

.hero-title { font-size: 24px; color: #ffffff; font-weight: 900; margin-bottom: 8px; line-height: 1.3; }
.hero-desc { font-size: 13px; color: rgba(255,255,255,0.8); line-height: 1.5; }

.content-section { background-color: #ffffff; border-radius: 24px; padding: 24px 20px; margin-top: -20px; position: relative; z-index: 10; min-height: 500px; }
.section-header { flex-direction: row; justify-content: space-between; align-items: center; margin-bottom: 20px; padding-bottom: 16px; border-bottom: 1px solid #f3f4f6; }
.section-title { font-size: 17px; font-weight: bold; color: #1f2937; }
.section-action { font-size: 13px; color: #ec4899; font-weight: bold; }

.quote-list { flex-direction: column; }
