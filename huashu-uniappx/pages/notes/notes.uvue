.notes-title { font-size: 22px; font-weight: 900; color: #ffffff; margin-bottom: 8px; }
.notes-desc { font-size: 12px; color: rgba(255,255,255,0.8); line-height: 1.5; }

.empty-state { flex: 1; align-items: center; justify-content: center; padding-bottom: 100px; }
.empty-icon { font-size: 48px; margin-bottom: 16px; opacity: 0.5; }
.empty-text { font-size: 14px; color: #9ca3af; }

.scroll-area { flex: 1; padding: 16px; }
.note-card { background-color: #ffffff; border-radius: 20px; padding: 16px; margin-bottom: 16px; box-shadow: 0 4px 12px -4px rgba(0,0,0,0.05); }
.note-time-row { flex-direction: row; justify-content: space-between; align-items: center; margin-bottom: 12px; padding-bottom: 8px; border-bottom-width: 1px; border-bottom-style: dashed; border-bottom-color: #f3f4f6; }
.note-time { font-size: 11px; color: #9ca3af; }
.note-status { font-size: 10px; font-weight: bold; padding: 2px 6px; border-radius: 6px; }
.status-reviewed { color: #059669; background-color: #ecfdf5; }
.status-pending { color: #ea580c; background-color: #fff7ed; }

.note-q-box { background-color: #fef2f2; padding: 10px; border-radius: 12px; margin-bottom: 8px; flex-direction: row; }
.note-label-q { font-size: 12px; font-weight: bold; color: #b91c1c; width: 60px; flex-shrink: 0; }
.note-q-text { font-size: 13px; color: #7f1d1d; flex: 1; line-height: 1.4; }

.note-a-box { background-color: #f3f4f6; padding: 10px; border-radius: 12px; margin-bottom: 12px; flex-direction: row; }
.note-label-a { font-size: 12px; font-weight: bold; color: #4b5563; width: 66px; flex-shrink: 0; }
.note-a-text { font-size: 13px; color: #374151; flex: 1; line-height: 1.4; }

.ai-review-box { background-image: linear-gradient(to right, #fdf2f8, #fce7f3); padding: 12px; border-radius: 16px; border-width: 1px; border-style: solid; border-color: #fbcfe8; }
.ai-review-header { flex-direction: row; align-items: center; margin-bottom: 8px; }
.ai-icon { font-size: 14px; margin-right: 6px; }
.ai-title { font-size: 13px; font-weight: bold; color: #be185d; }
.ai-comment { font-size: 12px; color: #9d174d; line-height: 1.5; margin-bottom: 12px; }
.ai-better-a { background-color: #ffffff; padding: 10px; border-radius: 10px; border-left-width: 3px; border-left-style: solid; border-left-color: #ec4899; }
.ai-better-label { font-size: 11px; font-weight: bold; color: #db2777; margin-bottom: 4px; }
.ai-better-text { font-size: 13px; color: #1f2937; font-weight: bold; }

.review-btn { background-color: #1f2937; padding: 10px 0; border-radius: 16px; align-items: center; }
.review-btn-text { color: #ffffff; font-size: 13px; font-weight: bold; }

.bottom-spacer { height: 40px; }
</style>
