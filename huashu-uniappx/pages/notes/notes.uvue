<template>
  <view class="container">
    <view class="notes-header bg-gradient-rose">
      <view class="header-inner">
        <text class="notes-title">情商错题本</text>
        <text class="notes-desc">记录那些让你“冷场”的送命题，AI 导师会定期帮你复盘，提升你的恋爱段位。</text>
      </view>
    </view>

    <view v-if="notes.length === 0" class="empty-state">
      <text class="empty-icon">📝</text>
      <text class="empty-text">你的错题本空空如也，情商很高嘛！</text>
    </view>

    <scroll-view v-else class="scroll-area" scroll-y>
      <view class="note-card" v-for="(note, idx) in notes" :key="idx">
        <view class="note-time-row">
          <text class="note-time">{{ note.date }}</text>
          <text class="note-status" :class="note.isReviewed ? 'status-reviewed' : 'status-pending'">{{ note.isReviewed ? '已复盘' : '待复盘' }}</text>
        </view>
        <view class="note-q-box">
          <text class="note-label-q">送命题：</text>
          <text class="note-q-text">{{ note.question }}</text>
        </view>
        <view class="note-a-box">
          <text class="note-label-a">我的回答：</text>
          <text class="note-a-text">{{ note.myAnswer }}</text>
        </view>
        <view v-if="note.isReviewed" class="ai-review-box">
          <view class="ai-review-header">
            <text class="ai-icon">🤖</text>
            <text class="ai-title">AI 导师点评</text>
          </view>
          <text class="ai-comment">{{ note.aiComment }}</text>
          <view class="ai-better-a">
            <text class="ai-better-label">高分示范：</text>
            <text class="ai-better-text">{{ note.aiBetterAnswer }}</text>
          </view>
        </view>
        <view v-else class="review-btn" @click="doReview(note)">
          <text class="review-btn-text">让 AI 帮我复盘</text>
        </view>
      </view>
      <view class="bottom-spacer"></view>
    </scroll-view>
  </view>
</template>

<script setup lang="uts">
import { ref } from 'vue'
import { useAppStore } from '../../store/app.uts'

const appStore = useAppStore

const notes = ref([
  {
    date: '2023-11-20 20:30',
    question: '你觉得我闺蜜好看还是我好看？',
    myAnswer: '都挺好看的呀，各有千秋。',
    isReviewed: true,
    aiComment: '兄弟，这是经典的送命题！回答“都好看”等于在女生雷区蹦迪。这种时候必须毫不犹豫、坚定且带有唯一性地偏向她。',
    aiBetterAnswer: '你闺蜜长啥样我都没看清，我眼里只有你。'
  },
  {
    date: '2023-11-22 14:15',
    question: '我好像感冒了，好难受。',
    myAnswer: '多喝点热水，吃点感冒药，好好休息。',
    isReviewed: false,
    aiComment: '',
    aiBetterAnswer: ''
  }
])

const doReview = (note: any) => {
  uni.showLoading({ title: 'AI 导师分析中...' })
  setTimeout(() => {
    uni.hideLoading()
    note.isReviewed = true
    note.aiComment = '经典的“多喝热水”直男发言。女生生病时需要的是情绪价值和实际行动，而不是做医嘱指导。'
    note.aiBetterAnswer = '怎么这么不小心，严重吗？开门，我带了粥和药在楼下。'
    appStore.showToast('复盘完成')
  }, 1500)
}
</script>

<style>
page { background-color: #f9fafb; height: 100%; }
