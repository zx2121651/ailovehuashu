.pro-text { color: #ffffff; font-size: 10px; }
.app-subtitle { font-size: 12px; color: #9ca3af; margin-top: 4px; font-weight: 500; }
.bell-btn { width: 36px; height: 36px; background-color: #f9fafb; border-radius: 18px; align-items: center; justify-content: center; border-width: 1px; border-style: solid; border-color: #f3f4f6; }
.bell-icon { font-size: 18px; }

/* Search */
.search-bar-wrap { flex-direction: row; align-items: center; background-color: #f9fafb; border-radius: 16px; padding: 0 6px 0 16px; height: 48px; }
.search-icon { font-size: 16px; color: #9ca3af; margin-right: 8px; }
.search-input { flex: 1; font-size: 14px; color: #374151; background-color: transparent; }
.search-btn { background-color: #111827; padding: 8px 16px; border-radius: 12px; }
.search-btn-text { color: #ffffff; font-size: 12px; font-weight: 500; }

/* Hot Tags */
.hot-tags-scroll { margin-top: 16px; height: 36px; }

.hot-label-wrap { flex-direction: row; align-items: center; margin-right: 8px; flex-shrink: 0; }
.hot-label-icon { font-size: 14px; color: #ef4444; margin-right: 4px; }
.hot-label-text { font-size: 11px; font-weight: bold; color: #374151; }
.hot-tag { background-color: #f9fafb; border-width: 1px; border-style: solid; border-color: #f3f4f6; padding: 6px 12px; border-radius: 20px; margin-right: 8px; flex-shrink: 0; }
.hot-tag-text { font-size: 11px; color: #6b7280; }

.hot-tags-scroll { white-space: nowrap; direction: ltr; width: 100%; height: 32px; }
.hot-label-wrap { display: inline-flex; flex-direction: row; align-items: center; vertical-align: top; }
.hot-tag { display: inline-flex; flex-direction: row; align-items: center; vertical-align: top; }

</style>
