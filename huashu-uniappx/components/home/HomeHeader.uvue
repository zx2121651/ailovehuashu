<template>
  <view class="header-area animate-fade-in-up">
    <view class="header-top">
      <view class="header-left">
        <view class="title-row">
          <text class="app-title">恋爱话术库</text>
          <view class="pro-badge animate-pulse-slow" @click="$emit('open-vip')">
            <text class="pro-text">Pro</text>
          </view>
        </view>
        <text class="app-subtitle">今天想撩谁？一句顶一万句</text>
      </view>
      <view class="bell-btn" @click="$emit('show-toast', '暂无新通知')">
        <text class="bell-icon">🔔</text>
      </view>
    </view>

    <!-- Search Bar -->
    <view class="search-bar-wrap">
      <text class="search-icon">🔍</text>
      <input
        type="text"
        v-model="searchInput"
        placeholder='搜一下：女生说"早安"怎么回'
        class="search-input"
        @confirm="handleSearch"
      />
      <view class="search-btn" @click="handleSearch">
        <text class="search-btn-text">搜索</text>
      </view>
    </view>

    <!-- Hot Search Tags -->
    <scroll-view class="hot-tags-scroll" scroll-x="true">
        <view class="hot-label-wrap">
          <text class="hot-label-icon">📈</text>
          <text class="hot-label-text">猜你想搜</text>
        </view>
        <view
          v-for="(tag, idx) in hotTags"
          :key="idx"
          class="hot-tag"
          @click="handleTagClick(tag)"
        >
          <text class="hot-tag-text">{{ tag }}</text>
        </view>
    </scroll-view>
  </view>
</template>

<script setup lang="uts">
import { ref } from 'vue'

const props = defineProps<{
  hotTags: string[]
}>()

const emit = defineEmits<{
  (e: 'search', keyword: string): void
  (e: 'open-vip'): void
  (e: 'show-toast', message: string): void
}>()

const searchInput = ref('')

const handleSearch = () => {
  if (searchInput.value.trim()) {
    emit('search', searchInput.value)
  }
}

const handleTagClick = (tag: string) => {
  emit('search', tag)
}
</script>

