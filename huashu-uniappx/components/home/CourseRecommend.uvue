<template>
  <view class="section animate-fade-in-up delay-250" v-if="courses.length > 0">
    <view class="section-header">
      <view class="section-title-row">
        <text class="section-title-icon">👑</text>
        <text class="section-title">精选课程</text>
      </view>
    </view>
    <scroll-view class="courses-scroll" direction="horizontal">
      <view class="courses-row">
        <view
          v-for="course in courses"
          :key="course.id"
          class="course-card bg-gradient-rose"
          @click="handleClick(course)"
        >
          <image :src="course.cover" class="course-cover-img" mode="aspectFill" @error="handleImgError" />
          <view class="course-mask"></view>
          <view class="course-content">
            <view class="course-tags-row">
              <view v-for="(tag, idx) in (course.tags || []).slice(0, 2)" :key="idx" class="course-tag">
                <text class="course-tag-text">{{ tag }}</text>
              </view>
              <view class="course-rating-badge" v-if="course.rating && course.rating > 0">
                <text class="course-rating-icon">🔥</text>
                <text class="course-rating-text">{{ course.rating }}分</text>
              </view>
            </view>
            <text class="course-title" :lines="1">{{ course.title }}</text>
            <view class="course-bottom">
              <text class="course-desc" :lines="1">{{ course.desc }}</text>
              <view class="course-play-btn">
                <text class="course-play-text">学习 ▶</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</template>

<script setup lang="uts">
const props = defineProps<{
  courses: any[]
}>()

const emit = defineEmits<{
  (e: 'open-course', course: any): void
}>()

const handleClick = (course: any) => {
  emit('open-course', course)
}

const handleImgError = (e: any) => {
  // Ignore
}
</script>

