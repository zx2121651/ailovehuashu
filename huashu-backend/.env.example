# 数据库连接字符串 (PostgreSQL)
# 格式: postgresql://用户名:密码@主机:端口/数据库名?schema=public
DATABASE_URL="postgresql://huashu:huashu_password@localhost:5432/huashu_db?schema=public"

# 服务端口
PORT=3000

# JWT 密钥（用于用户认证）
JWT_SECRET="your-secret-key-here"

# 环境模式
NODE_ENV=production
DATABASE_URL="postgresql://huashu:huashu_password@localhost:5432/huashu_db?schema=public"
